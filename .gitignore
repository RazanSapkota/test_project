# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
/bin/
/build/
/dist/

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
coverage.*

# Go workspace file
go.work
go.work.sum

# Dependency directory (usually vendored deps are committed, but ignore by default)
/vendor/

# Environment variable files
.env
.env.*
!.env.example

# Log files
*.log

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
